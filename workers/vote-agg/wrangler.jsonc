{
  "name": "vote-agg",
  "main": "src/index.js",
  "compatibility_date": "2025-01-01",
  "observability": { "enabled": true },
  "triggers": { "crons": ["0 0 * * *"] },
  "kv_namespaces": [{ "binding": "VOTES", "id": "REPLACE_WITH_KV_ID" }],
  "routes": [{ "pattern": "votes.bci.place", "custom_domain": true }]
}
