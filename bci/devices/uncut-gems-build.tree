\subtree{
  \title{8. Acceptance criteria}

  \table{
    \tr{\th{Claim}\th{Evidence required}\th{If missing}}
    \tr{\td{Buildable}\td{rail measurements, boot log, SMA-compatible connectors, RF passive inspection}\td{Resolve inventory, power, or RF connector issue before acceptance}}
    \tr{\td{Microwave source}\td{PLL/LOCK trace, output evidence, RF continuity/bias}\td{Repair PLL/RF stage before acceptance}}
    \tr{\td{Optical coupling}\td{prism photo, laser/diamond/aerial alignment + dark/light contrast}\td{Repair prism, laser, or detector alignment before acceptance}}
    \tr{\td{ODMR candidate}\td{repeatable sweep with baseline, dip, recorded settings}\td{Repair ADC or sweep path before acceptance}}
    \tr{\td{INA333 improvement}\td{stock-vs-rework noise comparison, unchanged RF sweep}\td{Revert or repair the daughterboard before acceptance}}
  }
}

\subtree{
  \title{9. Open items — known issue, verify-on-board, and holds}

  \table{
    \tr{\th{ID}\th{Type}\th{Item}\th{Action}}
    \tr{\td{KI-1}\td{Known issue (designer) — build a NEW rework board}\td{The shipped PCB couples RF energy into the detector / \code{ADC_SIGNAL} path, corrupting the analog baseline so ODMR dips are noisy/ambiguous}\td{Build a new INA333 daughterboard (WI-10) — not present on the board as shipped — that drives one clean, isolated \code{ADC_SIGNAL} to the ESP32. The board ships needing this fix; it is the designer-flagged optimization, not a defect to reject}}
    \tr{\td{V-1}\td{Verify on board}\td{SMA connectors (J1–J4, J6)}\td{Confirm the SMA fits and passes RF continuity — use the existing/populated SMA if it works; only swap to the Molex 73251-2120 horizontal edge-mount if it genuinely will not fit or fails continuity. Part/function check, not a footprint redesign}}
    \tr{\td{V-2}\td{Verify}\td{RF amp population + external 40 dB module integration}\td{Inspect bias/matching before any RF claim}}
    \tr{\td{V-3}\td{Verify}\td{Prism geometry + detector baseline}\td{Co-locate diamond/aerial/laser and prove detector baseline before interpreting any trace}}
  }

  \p{Non-conformance: any failed acceptance item or damaged CFM is reported with photos within 1 working day; rework path agreed in writing before proceeding.}
}

\subtree{
  \title{10. Out of scope for the assembler}

  \p{NV-diamond sourcing/certification, physics-grade optical calibration science, host-side trace analysis/plotting, and any magnetometry-performance claims. No BCI claim — this is a laser + RF instrument.}
}

\subtree{
  \title{11. Packaging & return}

  \p{Finished unit returned in ESD packaging with laser/RF safed and the prism protected, plus the digital WI-11 evidence bundle and the signed §7/§8 tables.}
}
