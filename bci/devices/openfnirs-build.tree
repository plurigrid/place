    \tr{\td{ECU ×1}\td{RESET / SW1 tactile switch}\td{Source-spec ECU map + current ECU photo + May 27 checklist}\td{FSM1LP tactile switch stock: \image{hardware-builds/bci-pasted/2026-06-12-packet/07-digikey-fsm1lp-tactile-switch-qty3.png}}\td{SW1 footprint exists in the KiCad coordinate source; current photo verifies as-received condition}\td{Fit-check and solder only if body/pin geometry matches}}
    \tr{\td{ECU ×1}\td{U8/U4/U7/U3 IC footprints}\td{Source-spec ECU map + current ECU photo + May 27 checklist}\td{LM1085 3.3 V regulator stock for U3: \image{hardware-builds/bci-pasted/2026-06-12-packet/08-mouser-lm1085is-3v3-regulator.png} TMUX1104 stock is verify-only unless a mux site is proven empty: \image{hardware-builds/bci-pasted/2026-06-12-packet/14-mouser-tmux1104dgsr-mux.png}}\td{Footprints exist in the KiCad coordinate source; current photo/microscope check decides as-received population}\td{Fit-check and place only after designator/value confirmation; prove 3.3 V rail before downstream population}}
    \tr{\td{ECU ×1}\td{J3 SWD header}\td{Source-spec ECU map + current ECU photo + May 27 checklist}\td{FTSH-107 SMD header stock: \image{hardware-builds/bci-pasted/2026-06-12-packet/10-digikey-sam9449-ftsh-107-header.png}}\td{J3 exists in the KiCad coordinate source}\td{Populate SWD/header only as the BOM and flash path require; buy one extra FTSH if no spare is found}}
    \tr{\td{ECU ×1}\td{5V INPUT silkscreen / USB port J2 / SD1}\td{Source-spec ECU map + current ECU photo + May 27 checklist}\td{Molex 67503-1020 Mini-B receptacle stock for J2: \image{hardware-builds/bci-pasted/2026-06-12-packet/09-mouser-molex-67503-1020-mini-b.png}}\td{J2 and SD1 exist in the KiCad coordinate source; 5V INPUT is silkscreen}\td{Install only matched power/USB/storage parts; prove USB +5 V, enumeration, and rail behavior before using the board}}
    \tr{\td{ECU ×1}\td{Every source TP(n) coordinate}\td{Source-spec ECU map + current ECU photo}\td{No part image; test pads are not components}\td{TP footprints exist in the KiCad coordinate source}\td{Do not populate as parts; use for continuity, power, SWD, and bring-up evidence}}
    \tr{\td{ST-LINK adapter ×5}\td{HTSW J1 and FTSH J2 header pads}\td{Source-spec adapter map + bare adapter-board packet photo}\td{Bare ST-LINK adapter boards: \image{hardware-builds/bci-pasted/2026-06-12-packet/00-prior-stlink-breakout-boards.png} FTSH-107 SMD header stock: \image{hardware-builds/bci-pasted/2026-06-12-packet/10-digikey-sam9449-ftsh-107-header.png} No saved HTSW image exists in the packet}\td{J1/J2 footprints are from the ST-LINK KiCad source; current photo verifies the adapter PCBs are bare}\td{Buy HTSW-107-07-G-D and one FTSH-107-01-L-DV-K; verify against the bare adapter PCB pads before soldering}}
  }
}

