\subtree{
  \title{8. Acceptance criteria}

  \table{
    \tr{\th{Claim}\th{Evidence required}\th{If missing}}
    \tr{\td{Board stack complete}\td{8 sensor photos, ECU photo, adapter photo, BOM counts}\td{Resolve missing inventory or population before acceptance}}
    \tr{\td{Electrical acquisition}\td{3.3 V rail, reset, mux truth table, ADC dark/light samples}\td{Repair or rework the failed electrical stage before acceptance}}
    \tr{\td{Optical fNIRS timing}\td{660/940 nm current + optical bounds + frame timing}\td{Repair emitter/detector timing before acceptance}}
    \tr{\td{Host handoff}\td{USB frame log and bci.place-provided ingest output with channel, wavelength, and cap-position labels matching the hardware map}\td{Correct frame/channel mapping before acceptance}}
  }

  \p{Acceptance = bci.place review of the WI-9 evidence bundle within 5 working days of delivery.}
}

