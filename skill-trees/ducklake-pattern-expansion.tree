\title{Purpose}
\p{Enable progressive pattern discovery through 3 expansion waves:}

\ul{
\li{\strong{Wave 1:} Direct matches (high confidence ≥0.95)}
\li{\strong{Wave 2:} Relational discovery (medium confidence ≥0.75)}
\li{\strong{Wave 3:} Structural analysis (exploration confidence ≥0.50)}
}
}

