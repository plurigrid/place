\subtree{
\title{Triangle Inequality Constraints}
\p{For worlds W1, W2, W3:}

\pre{\startverb
d(W1, W3) ≤ d(W1, W2) + d(W2, W3)
\stopverb}

\p{Example:}

\ul{
\li{d(temporal, cognitive) = 5.49}
\li{d(temporal, structural) + d(structural, cognitive) = 2.87 + 3.14 = 6.01}
\li{Constraint satisfied: 5.49 ≤ 6.01 ✓}
}
}

