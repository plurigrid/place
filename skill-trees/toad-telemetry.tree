\title{Untitled}

\taxon{skill}

\subtree{
\title{Toad Telemetry Skill}
\p{OpenTelemetry instrumentation for Batrachian Toad AI agent terminal.}

\subtree{
\title{Overview}
\p{Provides deep observability into Toad agent sessions:}

\ul{
\li{\strong{Per-tool spans}: Every tool call (Bash, Read, Write, etc.) gets its own span}
\li{\strong{Turn tracking}: Prompt вҶ’ response cycles with timing}
\li{\strong{Session lifecycle}: Start/stop with agent metadata}
\li{\strong{Error tracking}: Exceptions and error states captured}
}
}

\subtree{
\title{Installation}
\pre{\startverb
# Install Toad
uv tool install batrachian-toad --python 3.14

# Install OTEL SDK in Toad's environment
uv pip install opentelemetry-sdk opentelemetry-exporter-otlp \
  --python ~/.local/share/uv/tools/batrachian-toad/bin/python3

# Install toad_telemetry library
mkdir -p ~/.local/lib/toad_telemetry
cp instrumentation.py ~/.local/lib/toad_telemetry/
cp __init__.py ~/.local/lib/toad_telemetry/

# Install wrapper script
cp toadia ~/.local/bin/
chmod +x ~/.local/bin/toadia
\stopverb}
}

\subtree{
\title{Usage}
\subtree{
\title{Via Wrapper Script (Recommended)}
\pre{\startverb
# Run toad with telemetry enabled
toadia -a claude .

# Run ACP agent with telemetry
toadia acp "my-command" .

# Disable telemetry
TOAD_TELEMETRY_ENABLED=0 toadia -a claude .
\stopverb}
}

\subtree{
\title{Programmatic}
\pre{\startverb
from toad_telemetry import instrument_toad, ToadTelemetryConfig

config = ToadTelemetryConfig(
    service_name="my-toad-session",
    endpoint="http://localhost:4317",
    agent_name="claude",
    project_dir="/path/to/project",
)

instrument_toad(config)

# Now run toad normally
from toad.cli import main
main()
\stopverb}
}
}

\subtree{
\title{Environment Variables}
\pre{\startverb
| Variable | Default | Description |
|----------|---------|-------------|
| `OTEL_EXPORTER_OTLP_ENDPOINT` | `http://localhost:4317` | OTLP collector endpoint |
| `TOAD_TELEMETRY_ENABLED` | `1` | Enable/disable telemetry |
| `TOAD_TELEMETRY_CONSOLE` | `0` | Print spans to console |
| `TOAD_SERVICE_NAME` | `toad` | Service name in traces |
\stopverb}
}

\subtree{
\title{Quick Start with Jaeger}
\pre{\startverb
# Start Jaeger
docker run -d --name jaeger \
  -p 16686:16686 \
  -p 4317:4317 \
  jaegertracing/all-in-one:latest

# Run toadia
toadia -a claude .

# View traces at http://localhost:16686
\stopverb}
}

\subtree{
\title{Span Attributes}
\subtree{
\title{Tool Spans (tool name)}
\ul{
\li{\code{\startverb toad.tool.id\stopverb} - Unique tool call ID}
\li{\code{\startverb toad.tool.name\stopverb} - Tool name (Bash, Read, Write, etc.)}
\li{\code{\startverb toad.tool.kind\stopverb} - Tool category}
\li{\code{\startverb toad.tool.status\stopverb} - Completion status}
\li{\code{\startverb toad.tool.duration_ms\stopverb} - Execution time}
\li{\code{\startverb toad.tool.error\stopverb} - Error message (if any)}
\li{\code{\startverb toad.session.id\stopverb} - Session identifier}
\li{\code{\startverb toad.agent\stopverb} - Agent name}
}
}

\subtree{
\title{Turn Spans (\code{\startverb agent.turn\stopverb})}
\ul{
\li{\code{\startverb toad.prompt.length\stopverb} - Input prompt character count}
\li{\code{\startverb toad.turn.stop_reason\stopverb} - Why the turn ended}
\li{\code{\startverb toad.turn.duration_ms\stopverb} - Total turn time}
\li{\code{\startverb toad.agent\stopverb} - Agent name}
}
}
}

