OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io:443 \
OTEL_EXPORTER_OTLP_HEADERS="x-honeycomb-team=YOUR_API_KEY" \
toadia -a claude .
\stopverb}
}
}

\subtree{
\title{Troubleshooting}
\subtree{
\title{"OpenTelemetry not available"}
\p{Install the SDK in Toad's Python environment:}

\pre{\startverb
uv pip install opentelemetry-sdk opentelemetry-exporter-otlp \
  --python ~/.local/share/uv/tools/batrachian-toad/bin/python3
\stopverb}
}

\subtree{
\title{No spans appearing}
\ol{
\li{Check collector is running: \code{\startverb docker ps | grep jaeger\stopverb}}
\li{Enable console export: \code{\startverb TOAD_TELEMETRY_CONSOLE=1 toadia ...\stopverb}}
\li{Verify telemetry enabled: \code{\startverb TOAD_TELEMETRY_ENABLED=1\stopverb}}
}
}

\subtree{
\title{gRPC connection errors}
\p{Try HTTP exporter (port 4318 instead of 4317):}

\pre{\startverb
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318 toadia -a claude .
\stopverb}
}
}

\subtree{
\title{Related Skills}
\ul{
\li{\code{\startverb otel-cli\stopverb} - Command-line OTEL span emission}
\li{\code{\startverb claude_telemetry\stopverb} - Similar instrumentation for Claude Code CLI}
}
}
}
