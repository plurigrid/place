\subtree{
\title{How It Works}
\p{The instrumentation uses deferred monkey-patching via Python import hooks to avoid circular imports:}

\ol{
\li{\code{\startverb instrument_toad()\stopverb} installs an import hook that waits for \code{\startverb toad.app\stopverb} to load}
\li{Once Toad is fully initialized, it patches \code{\startverb Agent.rpc_session_update\stopverb} and \code{\startverb Agent.send_prompt\stopverb}}
\li{\code{\startverb rpc_session_update\stopverb} receives all ACP protocol events (tool_call, tool_call_update, etc.)}
\li{Each tool call gets a span that tracks its lifecycle from start to completion}
\li{\code{\startverb send_prompt\stopverb} wraps each agent turn with timing and stop reason}
}
}

\subtree{
\title{Files}
\ul{
\li{\code{\startverb SKILL.md\stopverb} - This documentation}
\li{\code{\startverb \strong{init}.py\stopverb} - Package entry point}
\li{\code{\startverb instrumentation.py\stopverb} - Core monkey-patching and OTEL integration}
\li{\code{\startverb toadia\stopverb} - Wrapper script with Jaeger quickstart help}
}
}

