\subtree{
\title{continuation.zig to abductive-monte-carlo}
\p{AGM belief revision IS abductive reasoning:}

\ul{
\li{\code{\startverb expand\stopverb} = add hypothesis without consistency check (abduction)}
\li{\code{\startverb contract\stopverb} = remove refuted hypothesis (contraction)}
\li{\code{\startverb revise\stopverb} = Levi identity: contract negation, then expand (belief update)}
\li{Trit tracks hypothesis status: minus=refuted, zero=suspended, plus=accepted}
}
}

