\subtree{
\title{Module Anatomy (DeepWiki: plurigrid/zig-syrup)}
\subtree{
\title{1. propagator.zig -- Radul-Sussman Propagator Networks}
\pre{\startverb
// CellValue: partial information lattice
// Ordering: Nothing < Value < Contradiction
pub fn CellValue(comptime T: type) type {
    return union(enum) {
        nothing,                              // unknown
        value: T,                             // concrete
        contradiction: struct { a: T, b: T }, // conflict
    };
}

// latticeMerge: the join operation
// Nothing -> adopts incoming
// same Value -> idempotent
// different Value -> Contradiction
// Contradiction absorbs all
pub fn latticeMerge(existing: CellValue(T), incoming: CellValue(T)) CellValue(T) { ... }
\stopverb}

\ul{
\li{\strong{Cell}: holds CellValue + list of Propagator neighbors; alerts neighbors on change}
\li{\strong{Propagator}: inputs from Cells, applies function, sets output Cells}
\li{Bidirectional constraint propagation throughout the network}
\li{Special propagator functions: \code{\startverb neurofeedback_gate\stopverb} (BCI), \code{\startverb adjacency_gate\stopverb} (spatial), \code{\startverb focus_brightness\stopverb}}
\li{Connected to Orion Reed's "scoped propagators" concept}
}
}

\subtree{
\title{2. homotopy.zig -- Polynomial Homotopy Continuation}
\pre{\startverb
H(x, t) = (1 - t) * G(x) + t * F(x)
\stopverb}

\ul{
\li{Deformation from start system G (known solutions) to target system F}
\li{Complex number polynomial root tracking along paths}
\li{GF(3) trit classification per solution path: stable(+1), saddle(0), unstable(-1)}
\li{Integrates with syrup serialization (paths are Syrup-serializable)}
\li{Integrates with continuation.zig for resumable pipeline execution}
}
}

\subtree{
\title{3. continuation.zig -- AGM Belief Revision + GF(3) Trit Arithmetic}
\pre{\startverb
const Belief = struct { proposition: []const u8, entrenchment: f64 };
const BeliefSet = struct {
    beliefs: std.ArrayList(Belief),
    fn expand(self, b: Belief) void { ... }                // add without consistency check
    fn contract(self, prop: []const u8) void { ... }       // remove belief + negation
    fn revise(self, b: Belief) void {                      // Levi identity: (K - !p) + p
        self.contract(negate(b.proposition));
        self.expand(b);
    }
};

const Trit = enum { minus, zero, plus };  // -1, 0, +1
// Conserved across: serialization, transport, propagators, identity, BCI
\stopverb}
}

\subtree{
\title{4. QRTP -- QR Transfer Protocols (Air-Gapped Identity)}
\ul{
\li{Fountain-coded QR codes for data transfer across air gaps}
\li{Each source block = Cell, each encoded block = Propagator}
\li{Contradiction = transmission error detection}
\li{"Scoped propagators applied to erasure decoding" (Orion Reed connection)}
}
}

