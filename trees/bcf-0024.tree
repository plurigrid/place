\table{
  \tr{\th{Component} \th{Description}}
  \tr{\td{\code{did:gay}} \td{W3C DID method, successor to \code{did:plc}}}
  \tr{\td{Zig + WASM} \td{Zero-alloc \code{terminal://} pipeline, freestanding}}
  \tr{\td{OpenBCI Cyton} \td{8-ch EEG, 250 Hz, open hardware ([[bcf-0010]])}}
  \tr{\td{Syrup OCapN} \td{Capability-secure wire format ([[bcf-0017]])}}
  \tr{\td{Aptos Move} \td{On-chain DID registry, GF(3) multisig}}
  \tr{\td{Fisher-Rao} \td{Information geometry for EEG distance ([[horse-0003]])}}
}
}

\subtree{\title{Necessity filtration and dimension-stable identity}
\p{The 82 bits of EEG entropy are a dimension-stable #{k}-NN signature: a brain-state fingerprint that survives the Matryoshka Cliff at every truncation dimension. The GF(3) triadic identity (Generator +1, Ergodic 0, Validator -1) maps exactly onto the grading of the necessity filtration: Generator = unreflected tiles / refine phase, Ergodic = transfer matrix / peak phase, Validator = reflected tiles / coarse phase / obstruction detector.}
}

\subtree{\title{Research numbers}
\ul{
  \li{97 percent CNN identification accuracy (14-ch consumer EEG)}
  \li{82 bits of entropy from 8-channel resting EEG}
  \li{1.54 percent EER with multi-session adaptive enrollment}
  \li{14 tests passing in proof-of-brain Zig module}
  \li{0 biometric templates stored on disk or chain}
}
}
