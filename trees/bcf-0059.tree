\meta{institution}{BCI Factory}

\import{macros}

\p{The seventh system in the BCI Factory stack: \strong{gh CLI GraphQL streaming} into \strong{snapshottable DuckLake/DuckDB} with geo OLC extensions and a Syrup wire-format codec. Closes the loop from forester source-of-truth to version-controlled analytical storage.}

\p{Every tree in this forest has a GitHub commit. Every commit has a GraphQL node. Every node streams into DuckDB as a fact. Every fact gets an OLC for the physical location where it was authored (222 Dore = \code{849VQJG4+XX}). Every wire between facts speaks Syrup.}

\subtree{
\title{Architecture Triad}

\table{
  \tr{\th{Layer} \th{Tool} \th{Role} \th{Trit}}
  \tr{\td{Source} \td{gh CLI + GraphQL API} \td{Stream commits, trees, discussions as typed events} \td{+1}}
  \tr{\td{Transform} \td{Babashka + Syrup codec} \td{JSON events to Syrup canonical encoding to DuckDB rows} \td{0}}
  \tr{\td{Store} \td{DuckDB + DuckLake + spatial} \td{Snapshottable analytical storage with OLC geo column} \td{-1}}
}

\p{Conservation: +1 + 0 + (-1) = 0.}
}

\subtree{
\title{gh CLI GraphQL Streaming}

\p{\code{gh api graphql} accepts arbitrary queries against GitHub v4. We stream three object types per push:}

\table{
  \tr{\th{Object} \th{GraphQL Type} \th{Fields Extracted}}
  \tr{\td{Commits} \td{Commit} \td{oid, message, committedDate, author, tree.entries}}
  \tr{\td{Trees} \td{Tree} \td{entries: name, type, object.text (forester .tree content)}}
  \tr{\td{Discussions} \td{Discussion} \td{title, body, comments, labels, createdAt}}
}
}

\subtree{
\title{Syrup Wire Format}

\p{Every event between gh CLI and DuckDB is encoded in \strong{Syrup} -- the canonical wire format from zig-syrup. Self-describing binary, designed for capability-secure message passing (OCapN/CapTP).}

\p{Advantages over JSON for the DuckDB bridge:}

\ol{
  \li{\strong{Canonical}: identical data produces identical bytes. Syrup encoding of a tree IS its hash input.}
  \li{\strong{Compact}: 30-40 percent smaller than JSON for typical tree content.}
  \li{\strong{Type-preserving}: integers, floats, booleans, bytestrings, symbols have distinct wire types.}
  \li{\strong{CapTP-ready}: same format carries tree metadata AND EEG spectral summaries over Goblins CapTP.}
}
}

\subtree{
\title{DuckLake Schema}

\pre{%
INSTALL ducklake; LOAD ducklake;
INSTALL spatial; LOAD spatial;
ATTACH 'ducklake:///Users/bob/i/horse/bcf.ducklake' AS bcf;

CREATE TABLE bcf.trees (
    oid           VARCHAR,
    committed_at  TIMESTAMP,
    author        VARCHAR,
    tree_id       VARCHAR,
    title         VARCHAR,
    taxon         VARCHAR,
    tags          VARCHAR[],
    content_hash  VARCHAR,
    olc           VARCHAR,
    olc_point     GEOMETRY,
    syrup_bytes   BLOB,
    content       VARCHAR
);

CREATE TABLE bcf.eeg_sessions (
    session_id    VARCHAR,
    captured_at   TIMESTAMP,
    name_hash     UINT64,
    name_color    VARCHAR,
    brain_color   VARCHAR,
    color_gap     FLOAT,
    bands         STRUCT(delta FLOAT, theta FLOAT,
                         alpha FLOAT, beta FLOAT, gamma FLOAT),
    channels_ok   UINT8,
    olc           VARCHAR,
    olc_point     GEOMETRY,
    ttl_expires   TIMESTAMP
);
}

\p{Snapshot discipline: every \code{git push} = one DuckLake snapshot. Git history and DuckLake history are isomorphic. Time-travel in either system yields the same answer.}
}

