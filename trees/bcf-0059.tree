\pre{%
-- Spatial query: all trees within 200m of 222 Dore
SELECT tree_id, title
FROM bcf.trees
WHERE ST_DWithin(olc_point, ST_Point(-122.4230, 37.7697), 0.002)
ORDER BY ST_Distance(olc_point, ST_Point(-122.4230, 37.7697));
}
}

\subtree{
\title{Emacs Kiosk Integration}

\p{The kiosk at 222 Dore ([[bcf-0030]]) runs Emacs daemon. DuckLake bridge adds analytical queries:}

\pre{%
(defun bcf-query (sql)
  "Execute SQL against BCI Factory DuckLake."
  (shell-command-to-string
    (format "duckdb /Users/bob/i/horse/bcf.ducklake -csv -c %s"
            (shell-quote-argument sql))))

(defun bcf-tree-at-time (tree-id timestamp)
  "Show a tree as it existed at a given time."
  (interactive "sTree ID: \nsTimestamp: ")
  (let ((result (bcf-query
    (format "SELECT content FROM bcf.trees
             AT SNAPSHOT '%s'
             WHERE tree_id = '%s' LIMIT 1"
            timestamp tree-id))))
    (with-current-buffer (get-buffer-create "*bcf-timewarp*")
      (erase-buffer) (insert result) (forester-mode)
      (pop-to-buffer (current-buffer)))))

(defun bcf-sessions-today ()
  "Count self-serve EEG sessions today."
  (interactive)
  (message "Sessions: %s"
    (string-trim
      (bcf-query
        "SELECT COUNT(*) FROM bcf.eeg_sessions
         WHERE captured_at >= CURRENT_DATE"))))

(defun bcf-nearby-trees (olc)
  "Find trees authored near an OLC."
  (interactive "sOLC: ")
  (bcf-query
    (format "SELECT tree_id, title FROM bcf.trees
             WHERE olc = '%s' ORDER BY committed_at DESC LIMIT 20" olc)))
}
}

\subtree{
\title{Babashka Streaming Script}

\pre{%
#!/usr/bin/env bb
;; bcf-stream.bb -- gh GraphQL -> Syrup -> DuckLake

(require '[cheshire.core :as json]
         '[babashka.process :as p]
         '[clojure.string :as str])

(def query "{
  repository(owner: \"plurigrid\", name: \"horse\") {
    defaultBranchRef { target { ... on Commit {
      history(first: 10) { nodes {
        oid message committedDate
        author { name email }
        tree { entries { name type object { ... on Blob { text } } } }
      }}
    }}}
  }
}")

(defn gh-graphql [q]
  (-> (p/shell {:out :string} "gh" "api" "graphql" "-f" (str "query=" q))
      :out (json/parse-string true)))

(defn extract-trees [commit]
  (->> (get-in commit [:tree :entries])
       (filter #(str/ends-with? (:name %) ".tree"))
       (map (fn [e] {:oid (:oid commit)
                     :date (:committedDate commit)
                     :author (get-in commit [:author :name])
                     :tree-name (:name e)
                     :content (get-in e [:object :text])
                     :olc "849VQJG4+XX"}))))

(defn encode-syrup [val]
  (cond
    (integer? val)    (str val "+")
    (string? val)     (str (count val) "\"" val)
    (boolean? val)    (if val "t" "f")
    (keyword? val)    (let [s (name val)] (str (count s) "'" s))
    (map? val)        (str "{" (apply str
                        (mapcat (fn [[k v]]
                          [(encode-syrup k) (encode-syrup v)]) val)) "}")
    (sequential? val) (str "[" (apply str (map encode-syrup val)) "]")
    :else             (str (count (str val)) "\"" val)))

(defn ingest [trees]
  (doseq [t trees]
    (let [syrup (encode-syrup t)
          esc   #(str/replace % "'" "''")
          sql   (format "INSERT INTO bcf.trees
                  (oid,committed_at,author,tree_id,content_hash,olc,content)
                  VALUES ('%s','%s','%s','%s',md5('%s'),'%s','%s')"
                  (:oid t) (:date t) (esc (:author t))
                  (str/replace (:tree-name t) ".tree" "")
                  syrup (:olc t) (esc (or (:content t) "")))]
      (p/shell "duckdb" "/Users/bob/i/horse/bcf.ducklake" "-c" sql))))

(let [result  (gh-graphql query)
      commits (get-in result [:data :repository :defaultBranchRef
                              :target :history :nodes])]
  (doseq [c commits]
    (let [trees (extract-trees c)]
      (println (format "Commit %s: %d trees"
                (subs (:oid c) 0 7) (count trees)))
      (ingest trees))))
}
}

\subtree{
\title{Full 9-System Composition}

\table{
  \tr{\th{N} \th{System} \th{Role} \th{Trit}}
  \tr{\td{1} \td{Forester} \td{Source of truth} \td{+1}}
  \tr{\td{2} \td{SvelteKit} \td{Public web} \td{+1}}
  \tr{\td{3} \td{Ratzilla} \td{Kiosk TUI} \td{+1}}
  \tr{\td{4} \td{NATS} \td{Real-time transport} \td{0}}
  \tr{\td{5} \td{BrainFlow} \td{Hardware bridge} \td{0}}
  \tr{\td{6} \td{OCaml} \td{Verification} \td{-1}}
  \tr{\td{7} \td{gh GraphQL} \td{Event stream} \td{+1}}
  \tr{\td{8} \td{Syrup codec} \td{Wire format} \td{0}}
  \tr{\td{9} \td{DuckLake} \td{Analytical store} \td{-1}}
}

\p{Three triads of three. Each sums to zero. Systems 1-3 are renderers (+1 each, generation). Systems 4-5,8 are transports (0 each, coordination). Systems 6,9 are stores/verifiers (-1 each, validation). The remaining trit assignments balance.}

\p{The DuckLake snapshot is the analytical shadow of the forester forest. One is the source of truth (trees). The other is the queryable mirror (rows). The Syrup wire ensures content-addressing is preserved across the bridge. The OLC geo column grounds every fact in physical space.}
}

