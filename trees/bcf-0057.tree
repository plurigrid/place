\subtree{\title{mDNS Service Map}
\taxon{finding}

\p{Services broadcasting on the LAN, grouped by function:}

\ul{
\li{\strong{Smart home}: \code{_hue}, \code{_hap} (HomeKit), \code{_meshcop}/_trel/_srpl-tls (Thread), \code{_companion-link}}
\li{\strong{Media}: \code{_airplay}, \code{_raop} (AirPlay audio)}
\li{\strong{File sharing}: \code{_smb}, \code{_sftp-ssh}}
\li{\strong{Remote access}: \code{_ssh}, \code{_rfb} (VNC), \code{_eppc} (Apple Remote Events), \code{_remotepairing}}
\li{\strong{Printing}: \code{_ipp}, \code{_ipps}, \code{_pdl-datastream}, \code{_uscan}/_uscans}
\li{\strong{Monitoring}: \code{_screenpipe}}
}

\p{Notable: \code{_screenpipe} is broadcasting -- this is the Screenpipe local AI recording service. Should be restricted to VLAN 10.}
}

\subtree{\title{Bluetooth Proximity}
\taxon{finding}

\p{BLE scan from workstation. RSSI indicates physical proximity:}

\table{
\tr{\th{Device}\th{RSSI}\th{Type}\th{Notes}}
\tr{\td{Adv360 Pro}\td{connected}\td{Split keyboard}\td{Kinesis, primary input}}
\tr{\td{hatchery}\td{-54 dBm}\td{BLE beacon}\td{Unknown. Close proximity. Investigate.}}
\tr{\td{radhatter}\td{paired}\td{Unknown BLE}\td{No RSSI available}}
}

\p{The \code{hatchery} device at -54 dBm is within 2-3 meters. Identity unknown -- could be a development board, sensor, or someone else's device.}
}

