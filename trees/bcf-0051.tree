\subtree{\title{Capture attempts observed}
\p{The region included live desktop messaging, a remote messaging MCP, a desktop messaging MCP, automation-agent session capture, local session-log scans, and Aptos MCP processes. Publication boundary: command-line secrets, process ids, room ids, and raw transcript text are private evidence, not part of this tree.}
}

\subtree{\title{GF(3) conservation}
\table{
\tr{\th{Stalk}\th{Role}\th{This snapshot}}
\tr{\td{MINUS (-1)}\td{validators and analyzers}\td{time cutoff checks, deduplication, source inventory}}
\tr{\td{ERGODIC (0)}\td{coordinators and synthesizers}\td{cross-system aggregation, project-site mapping, redaction boundary}}
\tr{\td{PLUS (+1)}\td{generators and executors}\td{Forester tree, compact JSON snapshot, PR branch}}
}
\p{Conservation check: (-1) + 0 + (+1) = 0 mod 3.}
}

\subtree{\title{Public/private boundary}
\ol{
\li{Keep raw message bodies, room ids, exact DM titles, bearer tokens, and private path suffixes out of public commits.}
\li{Publish aggregate counts, system classes, capture roles, and reproducible redaction policy.}
\li{Keep local evidence files available for audit, but treat this tree and \code{bci/stages/interaction-sites-48h.json} as the PR-safe snapshot.}
}
}
