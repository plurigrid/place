}

\subtree{\title{Deploy Sequence}
\taxon{remark}

\ol{
\li{Flash UDM SE firmware to latest (container support)}
\li{Create VLANs 10/20/30 in UniFi controller}
\li{Deploy Pi-hole container on UDM SE}
\li{Deploy step-ca container, generate root CA}
\li{Move root key to YubiKey}
\li{Configure WPA3-Enterprise SSID with EAP-TLS}
\li{Move LG TV to VLAN 20 (static DHCP reservation)}
\li{Plug Tapo H200 into tagged VLAN 20 port via ethernet}
\li{Pair C420S3 cameras to H200, insert 512GB microSD}
\li{Add Starlink as WAN2 (failover or load-balance)}
}
}

