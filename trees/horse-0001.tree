\p{Open invitation: anyone can be the first rider. Come to 222 Dore.
Sit in the chair. Your wave starts when you sit.}
}

\subtree{
\title{The Pipeline}

\p{Four stages, 4.0ms critical path at 50Hz. Codename: \strong{T-55}.}

\ol{
  \li{\strong{Signal → Sites}: Electrode montage as Grothendieck topology. ([[horse-0002]], [[bci-stage-1]])}
  \li{\strong{Local → Cohomology}: Spectral analysis, Fisher-Rao, GF(3) encoding. ([[horse-0003]], [[bci-stage-2]])}
  \li{\strong{Global → Descent}: Gluing patches into whole-brain state. ([[horse-0004]], [[bci-stage-3]])}
  \li{\strong{Decode → Semantics}: Capability-secured intent via OCapN. ([[horse-0005]], [[bci-stage-4]])}
}

\p{The math: [[bci-0001]]. Current device state: [[bcf-devices]]. The games: [[bci-0006]].
