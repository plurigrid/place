\ul{
\li{JLCPCB (5× PCB + assembly): $130}
\li{Amazon (connectors + off-board): $251}
\li{Mouser (8× MMG3014NT1): $28}
\li{Adámas (1× diamond): $601}
\li{\strong{Total (first build): ~$1,010}}
\li{\strong{Total (all 3 builds, 3 diamonds): ~$2,212}}
}}

